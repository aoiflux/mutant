putln("=== Offline PCAP Analysis (Pure-Go backend) ===");

let pcap_path = "examples/data/sample_capture.pcap";
let present, err = fs_exists(pcap_path);
if (err) {
    putln("fs_exists error:", err);
} else if (!present) {
    putln("No sample PCAP found at", pcap_path);
    putln("Place a .pcap file there or change pcap_path to your capture file.");
} else {
    let report, err = net_pcap_analyze(pcap_path);
    putln("net_pcap_analyze:", report, "err:", err);
};
